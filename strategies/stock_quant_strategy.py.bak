import numpy as np
from vnpy_ctastrategy import (
    CtaTemplate,
    StopOrder,
    TickData,
    BarData,
    TradeData,
    OrderData,
    BarGenerator,
    ArrayManager,
)

class StockQuantStrategy(CtaTemplate):
    """
    逻辑自进化V6：动态风控与多维度共振趋势引擎
    主要改进：
    1. 彻底修复V5版本的“风控死锁”漏洞，改用动态风险乘数（Risk Multiplier），确保策略持续运行。
    2. 移除对外部基准指数的强依赖，增强单标的回测与实盘的健壮性。
    3. 引入三均线系统（10/30/120）与 RSI 强弱指标，过滤高位超买风险，捕捉中轨低吸机会。
    4. 优化止损止盈：初始 2.0*ATR 止损，引入 8% 利润保本机制，以及 15%/30% 的大比例分段止盈。
    5. 针对 A 股高单价股票（如贵州茅台）优化仓位计算，确保资金利用率最大化。
    """

    author = "Antigravity Quant - Evolved V6"

    # 资金与风控参数
    total_capital: float = 1_000_000.0
    risk_per_trade: float = 0.015           # 单笔风险比例（提高至1.5%以适应高价股）
    max_position_pct: float = 0.30          # 单次入场最大市值占比（提高至30%）
    
    # 账户回撤控制参数（动态降仓，不锁死）
    acct_dd_reduce: float = 0.08            # 回撤超8%风险减半
    acct_dd_min_risk: float = 0.15          # 回撤超15%风险降至一成（保留交易能力）

    # 均线与通道参数
    fast_ma_period: int = 10
    mid_ma_period: int = 30
    slow_ma_period: int = 120
    breakout_period: int = 20               # 唐奇安通道周期
    rsi_period: int = 14
    vol_period: int = 20

    # ATR与止损
    atr_period: int = 14
    initial_atr_stop: float = 2.0           # 初始追踪止损 ATR 倍数（收紧）
    stop_atr_profit1: float = 1.5           # 盈利 >15% 时的 ATR 倍数
    stop_atr_profit2: float = 1.0           # 盈利 >25% 时的 ATR 倍数
    
    # 止盈目标与比例
    target1: float = 0.15                   # 第一目标 15%
    target2: float = 0.30                   # 第二目标 30%
    sell_ratio1: float = 0.40               # 第一目标卖出40%（加大锁定利润）
    sell_ratio2: float = 0.40               # 第二目标再卖40%

    # 变量定义
    current_cash: float = 0.0
    fast_ma: float = 0.0
    mid_ma: float = 0.0
    slow_ma: float = 0.0
    atr: float = 0.0
    rsi_value: float = 0.0
    account_peak_value: float = 0.0
    current_risk_multiplier: float = 1.0

    parameters = [
        "total_capital",
        "risk_per_trade",
        "max_position_pct",
        "acct_dd_reduce",
        "acct_dd_min_risk",
        "fast_ma_period",
        "mid_ma_period",
        "slow_ma_period",
        "breakout_period",
        "rsi_period",
        "vol_period",
        "atr_period",
        "initial_atr_stop",
        "stop_atr_profit1",
        "stop_atr_profit2",
        "target1",
        "target2",
        "sell_ratio1",
        "sell_ratio2",
    ]
    variables = [
        "current_cash",
        "fast_ma",
        "mid_ma",
        "slow_ma",
        "atr",
        "rsi_value",
        "account_peak_value",
        "current_risk_multiplier",
    ]

    def on_init(self) -> None:
        self.write_log("策略V6初始化...")
        max_period = max(
            self.slow_ma_period,
            self.breakout_period,
            self.atr_period + 50
        ) + 100
        self.am: ArrayManager = ArrayManager(size=max_period)
        self.bg: BarGenerator = BarGenerator(self.on_bar)

        self.sub_positions: list = []
        self.current_cash = self.total_capital
        self.account_peak_value = self.total_capital
        self.current_risk_multiplier = 1.0
        self.load_bar(max_period)

    def on_start(self) -> None:
        self.write_log("策略V6启动")
        self.put_event()

    def on_stop(self) -> None:
        self.write_log("策略V6停止")
        self.put_event()

    def on_tick(self, tick: TickData) -> None:
        if tick.vt_symbol == self.vt_symbol:
            self.bg.update_tick(tick)

    def on_bar(self, bar: BarData) -> None:
        self.cancel_all()
        am = self.am
        am.update_bar(bar)
        if not am.inited:
            return

        close = bar.close_price
        high = bar.high_price
        low = bar.low_price
        volume = bar.volume

        # 1. 计算核心技术指标
        self.fast_ma = am.sma(self.fast_ma_period)
        self.mid_ma = am.sma(self.mid_ma_period)
        self.slow_ma = am.sma(self.slow_ma_period)
        self.atr = am.atr(self.atr_period)
        self.rsi_value = am.rsi(self.rsi_period)

        # 2. 动态账户风控计算（彻底解决死锁）
        acct_value = self.current_cash + sum(p["volume"] * close for p in self.sub_positions)
        self.account_peak_value = max(self.account_peak_value, acct_value)
        dd = (self.account_peak_value - acct_value) / self.account_peak_value if self.account_peak_value > 0 else 0.0

        if dd >= self.acct_dd_min_risk:
            self.current_risk_multiplier = 0.1  # 严重回撤，风险降至10%，但不停止交易
        elif dd >= self.acct_dd_reduce:
            self.current_risk_multiplier = 0.5  # 轻度回撤，风险减半
        else:
            self.current_risk_multiplier = 1.0  # 正常状态

        # 3. 管理现有持仓
        keep = []
        for pos in self.sub_positions:
            entry_price = pos["buy_price"]
            shares = pos["volume"]
            pos["highest"] = max(high, pos.get("highest", entry_price))
            highest = pos["highest"]
            profit = (close - entry_price) / entry_price

            # 动态收紧移动止损
            if profit < 0.15:
                stop_mult = self.initial_atr_stop
            elif profit < 0.25:
                stop_mult = self.stop_atr_profit1
            else:
                stop_mult = self.stop_atr_profit2

            trail_stop = highest - self.atr * stop_mult
            
            # 利润 > 8% 触发保本机制
            if profit >= 0.08:
                trail_stop = max(trail_stop, entry_price)

            # 更新并记录止损价
            pos["trailing_stop"] = max(pos.get("trailing_stop", trail_stop), trail_stop)

            # 触发移动止损
            if low <= pos["trailing_stop"]:
                self._close_pos(pos, max(pos["trailing_stop"], low), f"移动止损(利润:{profit*100:.2f}%)")
                continue

            # 趋势彻底反转保护：跌破中期均线且利润回吐
            if close < self.mid_ma and profit < 0.05:
                self._close_pos(pos, close, "跌破中期均线保护平仓")
                continue

            # 分段止盈逻辑
            sell_vol = 0
            if profit >= self.target2 and not pos.get("t2_hit", False):
                sell_vol = int(shares * self.sell_ratio2 / 100) * 100
                pos["t2_hit"] = True
            elif profit >= self.target1 and not pos.get("t1_hit", False):
                sell_vol = int(shares * self.sell_ratio1 / 100) * 100
                pos["t1_hit"] = True
                # 触发第一目标止盈后，止损线强制提升至保本价以上
                pos["trailing_stop"] = max(pos["trailing_stop"], entry_price * 1.02)

            if sell_vol > 0:
                if sell_vol >= pos["volume"]:
                    self._close_pos(pos, close, f"分段止盈2({profit*100:.1f}%)清仓")
                    continue
                else:
                    self.sell(close, sell_vol)
                    self.current_cash += sell_vol * close
                    pos["volume"] -= sell_vol
                    self.write_log(f"部分止盈 {sell_vol}股 @{close:.2f}，剩余 {pos['volume']}股")

            if pos["volume"] > 0:
                keep.append(pos)

        self.sub_positions = keep

        # 4. 入场逻辑（仅在无持仓时评估）
        if self.sub_positions:
            self.put_event()
            return

        # 趋势多头排列过滤
        trend_bullish = (close > self.slow_ma) and (self.fast_ma > self.mid_ma)

        if not trend_bullish:
            self.put_event()
            return

        # 过滤高位超买风险
        if self.rsi_value > 68:
            self.put_event()
            return

        # 信号1：突破唐奇安通道上轨 + 成交量放大
        highest_br = am.high[-self.breakout_period:].max()
        vol_ma = np.mean(am.volume[-self.vol_period:]) if am.count >= self.vol_period else volume
        vol_ok = volume > vol_ma * 1.2
        signal_breakout = (close > highest_br) and vol_ok and (close > bar.open_price)

        # 信号2：中期均线附近缩量回调企稳（均值回归低吸）
        pullback_pct = abs(low - self.mid_ma) / self.mid_ma
        near_mid_ma = pullback_pct < 0.015
        bullish_candle = close > bar.open_price
        rsi_healthy = 40 < self.rsi_value < 55
        signal_pullback = near_mid_ma and bullish_candle and rsi_healthy

        if not (signal_breakout or signal_pullback):
            self.put_event()
            return

        # 5. 动态仓位与风险管理计算
        # 初始止损价设定
        if signal_pullback:
            stop_price = low - self.atr * 1.5
        else:
            stop_price = close - self.atr * 2.0
        stop_price = max(stop_price, 0.01)

        # 计算单笔最大允许亏损金额
        allowed_loss = acct_value * self.risk_per_trade * self.current_risk_multiplier
        risk_per_share = close - stop_price
        if risk_per_share <= 0:
            risk_per_share = self.atr * 2.0

        # 计算股数（必须是100股的整数倍）
        vol_risk = int(allowed_loss / risk_per_share / 100) * 100
        vol_cash = int(self.current_cash * self.max_position_pct / close / 100) * 100
        final_vol = min(vol_risk, vol_cash)

        # 针对高价股（如茅台）的保底开仓逻辑：若资金足够且风险可控，至少允许买入100股
        if final_vol < 100 and self.current_cash >= close * 100:
            if (close - stop_price) * 100 <= allowed_loss * 1.5:  # 允许微调风险上限
                final_vol = 100

        if final_vol < 100:
            self.put_event()
            return

        # 执行买入开仓
        self.buy(close, final_vol)
        self.current_cash -= final_vol * close
        self.sub_positions.append({
            "buy_price": close,
            "volume": final_vol,
            "trailing_stop": stop_price,
            "highest": close,
            "t1_hit": False,
            "t2_hit": False,
        })
        
        self.write_log(
            f"买入开仓 {final_vol}股 @{close:.2f} | "
            f"初始止损: {stop_price:.2f} | "
            f"当前风险系数: {self.current_risk_multiplier:.2f}"
        )
        self.put_event()

    def _close_pos(self, pos: dict, price: float, reason: str) -> None:
        vol = pos["volume"]
        self.sell(price, vol)
        self.current_cash += vol * price
        pnl_pct = (price - pos["buy_price"]) / pos["buy_price"]
        self.write_log(f"平仓出场 {vol}股 @{price:.2f} | 原因: {reason} | 单笔盈亏: {pnl_pct*100:.2f}%")

    def on_order(self, order: OrderData) -> None:
        pass

    def on_trade(self, trade: TradeData) -> None:
        self.put_event()

    def on_stop_order(self, stop_order: StopOrder) -> None:
        pass